# Copy to .env and fill in values before deploying.
# Generate a secret key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False

# Comma-separated hostnames (no scheme), e.g. norasaysenglish.com,www.norasaysenglish.com
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Comma-separated origins with scheme, e.g. https://yourdomain.com,https://www.yourdomain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Optional: PostgreSQL (Railway, Render, etc.). Leave empty to use SQLite.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Set True on HTTPS production (or when behind a TLS-terminating proxy)
DJANGO_SECURE_SSL=True

# Serve uploaded media (teacher photo, game sounds/GIFs) from the app server.
# Use True for simple VPS/Railway with a persistent volume on /media.
DJANGO_SERVE_MEDIA=True
